# ==========================================
# Open Council - Environment Configuration
# Copy this file to .env and add your keys
# ==========================================

# Primary Cloud Models (Free Tiers Recommended)
GROQ_API_KEY="your_groq_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"

# Premium Cloud Models (Optional - Phase 3)
# AWS_ACCESS_KEY_ID="your_aws_key"
# AWS_SECRET_ACCESS_KEY="your_aws_secret"
# AWS_REGION_NAME="us-east-1"

# Local Inference (Optional - Auto-detected)
OLLAMA_BASE_URL="http://localhost:11434"

# Search Providers (Phase 2+)
TAVILY_API_KEY="your_tavily_key_here"
SERPER_API_KEY="your_serper_key_here"

# System Settings
DEBUG_MODE=False
MAX_CONCURRENT_REQUESTS=2