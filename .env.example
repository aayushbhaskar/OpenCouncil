# ==========================================
# Open Council - Environment Configuration
# Copy this file to .env and add your keys
# ==========================================

# Primary Cloud Models (Free Tiers Recommended)
GROQ_API_KEY="your_groq_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"
GROQ_MODEL="groq/llama-3.3-70b-versatile"
GEMINI_MODEL="gemini/gemini-2.5-flash"

# Optional Odin node-level model overrides
# If unset, each node uses the default fallback chain above.
# MUNINN_MODEL="gemini/gemini-2.5-flash"
# HUGINN_MODEL="groq/llama-3.3-70b-versatile"
# ODIN_MODEL="groq/llama-3.3-70b-versatile"

# Premium Cloud Models (Optional - Phase 3)
# AWS_ACCESS_KEY_ID="your_aws_key"
# AWS_SECRET_ACCESS_KEY="your_aws_secret"
# AWS_REGION_NAME="us-east-1"

# Local Inference (Optional - Auto-detected)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="ollama/llama3.1"

# Search Providers (Phase 2+)
TAVILY_API_KEY="your_tavily_key_here"
SERPER_API_KEY="your_serper_key_here"

# System Settings
DEBUG_MODE=False
MAX_CONCURRENT_REQUESTS=2
LITELLM_TIMEOUT_SECONDS=30

# Update Settings (Optional)
# You can also set these in chat with:
# /config set OPEN_COUNCIL_UPDATE_CHECK 0
# /config set OPEN_COUNCIL_AUTO_UPDATE 1
# OPEN_COUNCIL_UPDATE_CHECK=1
# OPEN_COUNCIL_AUTO_UPDATE=0